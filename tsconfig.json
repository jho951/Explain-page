{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true,

    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "baseUrl": "./",
    "rootDir": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "typeRoots": ["./src/shared/types", "./node_modules/@types"],
    "types": ["react", "react-dom", "node"],
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmitOnError": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "appDir": true,

  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "middleware.ts",
    ".next/types/**/*.ts",
    ".vscode/not-found.tsx"
  ],

  "exclude": ["node_modules", ".next"]
}
