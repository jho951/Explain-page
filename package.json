{
  "name": "explain-page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && npm run lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "_lint": "npm run lint",
    "_typecheck": "npm run typecheck",
    "_format": "npm run format",
    "_format:check": "npm run format:check"
  },
  "dependencies": {
    "@jho951/ui-components": "^0.1.4",
    "@reduxjs/toolkit": "^2.11.2",
    "accept-language": "^3.0.20",
    "clsx": "^2.1.1",
    "framer-motion": "^12.19.2",
    "gray-matter": "^4.0.3",
    "lodash": "^4.18.1",
    "marked": "^16.0.0",
    "next": "15.5.15",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "openai": "^5.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@svgr/webpack": "^8.1.0",
    "@types/lodash": "^4.17.20",
    "@types/marked": "^5.0.2",
    "@types/node": "^20",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "webpack": "^5.106.2"
  }
}
